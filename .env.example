# ─────────────────────────────────────────
# Autonomous Career Intelligence Agent
# .env.example — copy this to .env and fill values
# ─────────────────────────────────────────

# ── LLM Provider (Groq) ──────────────────
# Get free key → https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Web Search Tool (Tavily) ─────────────
# Get free key → https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ── LangSmith Tracing ────────────────────
# Get free key → https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=autonomous-career-agent

# ── Database ─────────────────────────────
DATABASE_URL=sqlite:///./db/career_agent.db

# ── API Settings ─────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Agent Settings ────────────────────────
MODEL_NAME=llama-3.3-70b-versatile
TEMPERATURE=0
MAX_TOKENS=4096
